{
  "name": "dspbr-pt",
  "version": "0.4.0",
  "description": "A WebGL2 GPU path-tracer that runs in your browser.",
  "type": "module",
  "dependencies": {
    "@gltf-transform/core": "^4.0.0",
    "@gltf-transform/extensions": "^4.0.0",
    "@gltf-transform/functions": "^4.0.0",
    "meshoptimizer": "^0.21.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch"
  },
  "files": [
    "dist/**",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DassaultSystemes-Technology/dspbr-pt"
  },
  "author": "Bastian Sdorra <bastian.SDORRA@3ds.com>",
  "license": "Apache-2.0"
}
