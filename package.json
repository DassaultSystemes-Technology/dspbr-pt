{
  "name": "dspbr-pt-dev",
  "private": true,
  "description": "dspbr-pt renderer and utilities",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "rimraf dist/ packages/lib/dist packages/viewer/dist",
    "build:slang-materials": "node tools/generate_slang_materials.mjs",
    "validate:shaders": "node tools/validate_shaders.mjs",
    "build": "yarn workspaces foreach --topological run build",
    "dev": "yarn workspace dspbr-pt-demos run dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DassaultSystemes-Technology/dspbr-pt"
  },
  "author": "Bastian Sdorra <bastian.SDORRA@3ds.com>",
  "license": "Apache-2.0",
  "devDependencies": {
    "rimraf": "^3.0.2",
    "typescript": "^5.5.0"
  },
  "packageManager": "yarn@3.2.0"
}
